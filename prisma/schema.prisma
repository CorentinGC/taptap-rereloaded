generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Song {
  id            String   @id @default(cuid())
  videoId       String   @unique
  url           String
  title         String
  duration      Int
  bpm           Int
  thumbnailUrl  String?
  audioUrl      String?
  beatmapEasy   Json?
  beatmapNormal Json?
  beatmapHard   Json?
  beatmapExpert Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
